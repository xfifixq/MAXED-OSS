# =============================================================================
# Maxed Platform API — Environment Variables
# =============================================================================
# Copy to .env and fill in values for your environment.

# ---------------------------------------------------------------------------
# Database (Supabase or self-hosted PostgreSQL)
# ---------------------------------------------------------------------------
# For Supabase: Use the connection string from your project settings.
# Go to: Supabase Dashboard > Project > Settings > Database > Connection string
# Use the "Transaction" pooler URL for Prisma (port 6543):
#   DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the "Session" pooler URL for migrations (port 5432):
#   DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
#
# For self-hosted PostgreSQL:
DATABASE_URL="postgresql://maxed:changeme@localhost:5432/maxed_unified?schema=public"
DIRECT_URL="postgresql://maxed:changeme@localhost:5432/maxed_unified?schema=public"

# ---------------------------------------------------------------------------
# API Security
# ---------------------------------------------------------------------------
# Set a strong API key for production. When set, all /api routes require
# X-API-Key header or Bearer token. Leave empty for development.
MAXED_API_KEY=""

# Server port
PORT=4000

# CORS — comma-separated list of allowed origins (default: * for dev)
# For production, set to your dashboard and portal URLs:
# Without SSL:
# CORS_ORIGINS="http://app.maxed.life,http://portal.maxed.life"
# With SSL:
# CORS_ORIGINS="https://app.maxed.life,https://portal.maxed.life"

# ---------------------------------------------------------------------------
# Supabase (optional — for auth and storage features)
# ---------------------------------------------------------------------------
# SUPABASE_URL="https://[project-ref].supabase.co"
# SUPABASE_ANON_KEY="eyJ..."
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ---------------------------------------------------------------------------
# Integrated Service URLs
# ---------------------------------------------------------------------------
PAPERLESS_URL="http://localhost:8000"
DOCUSEAL_URL="http://localhost:3003"
INVOICE_NINJA_URL="http://localhost:8080"
N8N_URL="http://localhost:5678"
KIMAI_URL="http://localhost:8001"
MATTERMOST_URL="http://localhost:8065"
METABASE_URL="http://localhost:3002"
TWENTY_URL="http://localhost:3004"

# ---------------------------------------------------------------------------
# Service API Tokens
# ---------------------------------------------------------------------------
# These tokens authenticate the platform API with each service.
# Generate them from each service's admin panel.

# Paperless-ngx: Settings > Django Admin > Auth Tokens
PAPERLESS_API_TOKEN=""

# DocuSeal: Settings > API
DOCUSEAL_API_TOKEN=""

# Invoice Ninja: Settings > Account Management > API Tokens
INVOICE_NINJA_API_TOKEN=""

# n8n: Settings > API > Create API Key
N8N_API_KEY=""

# Kimai: User Profile > API Access > Create API Token
KIMAI_API_USER="admin@maxed.dev"
KIMAI_API_TOKEN=""
