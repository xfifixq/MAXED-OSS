# =============================================================================
# Maxed Dashboard — Environment Variables
# =============================================================================
# Copy to .env.local and fill in values.

# Platform API URL
NEXT_PUBLIC_API_URL="http://localhost:4000"

# NextAuth
NEXTAUTH_URL="http://localhost:3005"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32

# Service URLs (for "Open in..." links)
NEXT_PUBLIC_PAPERLESS_URL="http://localhost:8000"
NEXT_PUBLIC_INVOICE_NINJA_URL="http://localhost:8080"
NEXT_PUBLIC_DOCUSEAL_URL="http://localhost:3003"
NEXT_PUBLIC_METABASE_URL="http://localhost:3002"
NEXT_PUBLIC_N8N_URL="http://localhost:5678"
NEXT_PUBLIC_MATTERMOST_URL="http://localhost:8065"
NEXT_PUBLIC_KIMAI_URL="http://localhost:8001"
NEXT_PUBLIC_TWENTY_URL="http://localhost:3004"

# Supabase (optional — set if using Supabase auth)
# NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
